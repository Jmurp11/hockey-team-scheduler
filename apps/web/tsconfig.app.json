{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": [],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "preserveSymlinks": true,
    "importsNotUsedAsValues": "remove",
    "verbatimModuleSyntax": false,
    "removeComments": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "ES2022"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.spec.ts"
  ]
}
